{
  "info": {
    "name": "Student Management System - All APIs",
    "description": "Complete API collection for all 4 microservices: Auth, User, Course, Marks",
    "_postman_id": "sms-microservices-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "auth_url",   "value": "http://localhost:8081", "type": "string" },
    { "key": "user_url",   "value": "http://localhost:8082", "type": "string" },
    { "key": "course_url", "value": "http://localhost:8083", "type": "string" },
    { "key": "marks_url",  "value": "http://localhost:8084", "type": "string" },
    { "key": "token",      "value": "", "type": "string", "description": "Set after login — auto-filled by login test script" }
  ],
  "item": [
    {
      "name": "1. Auth Service (8081)",
      "item": [
        {
          "name": "Register Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.token) { pm.collectionVariables.set('token', res.token); }",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token returned', () => pm.expect(res.token).to.not.be.empty);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{auth_url}}/api/auth/register", "host": ["{{auth_url}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_student\",\n  \"email\": \"john@sliit.lk\",\n  \"password\": \"password123\",\n  \"role\": \"STUDENT\"\n}"
            }
          }
        },
        {
          "name": "Register Teacher",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{auth_url}}/api/auth/register", "host": ["{{auth_url}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"dr_smith\",\n  \"email\": \"smith@sliit.lk\",\n  \"password\": \"password123\",\n  \"role\": \"TEACHER\"\n}"
            }
          }
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{auth_url}}/api/auth/register", "host": ["{{auth_url}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin_user\",\n  \"email\": \"admin@sliit.lk\",\n  \"password\": \"admin123\",\n  \"role\": \"ADMIN\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.token) { pm.collectionVariables.set('token', res.token); }",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token present', () => pm.expect(res.token).to.not.be.empty);",
                  "console.log('Token saved:', res.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{auth_url}}/api/auth/login", "host": ["{{auth_url}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_student\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Validate Token",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{auth_url}}/api/auth/validate?token={{token}}",
              "host": ["{{auth_url}}"],
              "path": ["api", "auth", "validate"],
              "query": [{ "key": "token", "value": "{{token}}" }]
            }
          }
        }
      ]
    },
